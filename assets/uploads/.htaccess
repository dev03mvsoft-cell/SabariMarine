# Disable execution of scripts in this directory
SetHandler default-handler
<Files *>
  SetHandler none
</Files>
Options -ExecCGI -Indexes
RemoveHandler .php .phtml .php3 .php4 .php5 .php6 .php7 .cgi .pl .asp .aspx .shtml .shtm .fcgi .fpl .jsp .htm .html .wml
AddType text/plain .php .phtml .php3 .php4 .php5 .php6 .php7 .cgi .pl .asp .aspx .shtml .shtm .fcgi .fpl .jsp .htm .html .wml
